[
  {
    "name": "owners",
    "type": "base",
    "schema": [
      { "name": "name", "type": "text", "required": true },
      { "name": "bio", "type": "text" },
      { "name": "city", "type": "text" },
      { "name": "lat", "type": "number" },
      { "name": "lng", "type": "number" },
      { "name": "avatar_url", "type": "url" },
      { "name": "user_id", "type": "relation", "relationId": "_pb_users_auth_", "unique": true }
    ]
  },
  {
    "name": "pets",
    "type": "base",
    "schema": [
      { "name": "owner", "type": "relation", "relationId": "owners", "required": true },
      { "name": "name", "type": "text", "required": true },
      { "name": "species", "type": "select", "options": { "values": ["dog", "cat", "rabbit", "bird", "other"] } },
      { "name": "breed", "type": "text" },
      { "name": "age_months", "type": "number" },
      { "name": "gender", "type": "select", "options": { "values": ["male", "female"] } },
      { "name": "size", "type": "select", "options": { "values": ["small", "medium", "large"] } },
      { "name": "intent", "type": "select", "options": { "values": ["playdate", "breeding", "both"] } },
      { "name": "description", "type": "text" },
      { "name": "is_vaccinated", "type": "bool" },
      { "name": "photos", "type": "file", "options": { "maxSelect": 5 } },
      { "name": "temperament_tags", "type": "json" }
    ]
  },
  {
    "name": "swipes",
    "type": "base",
    "schema": [
      { "name": "swiper_pet", "type": "relation", "relationId": "pets", "required": true },
      { "name": "swiped_pet", "type": "relation", "relationId": "pets", "required": true },
      { "name": "direction", "type": "select", "options": { "values": ["like", "pass"] } }
    ]
  },
  {
    "name": "matches",
    "type": "base",
    "schema": [
      { "name": "pet_a", "type": "relation", "relationId": "pets", "required": true },
      { "name": "pet_b", "type": "relation", "relationId": "pets", "required": true }
    ]
  },
  {
    "name": "messages",
    "type": "base",
    "schema": [
      { "name": "match", "type": "relation", "relationId": "matches", "required": true },
      { "name": "sender_owner", "type": "relation", "relationId": "owners", "required": true },
      { "name": "content", "type": "text", "required": true }
    ]
  }
]
